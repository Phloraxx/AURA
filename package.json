{
  "name": "aura",
  "version": "0.1.0",
  "private": true,
  "description": "Adaptive User-Responsive Accessibility",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm --filter @aura/shared build && corepack pnpm --parallel --filter @aura/extension --filter @aura/api dev",
    "build": "corepack pnpm -r --if-present build",
    "lint": "eslint .",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "test": "corepack pnpm -r --if-present test"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "eslint": "9.39.2",
    "globals": "16.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.0"
  }
}
