{
  "name": "aura",
  "version": "0.1.0",
  "private": true,
  "description": "Adaptive User-Responsive Accessibility",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "browser:dev": "corepack pnpm --filter @aura/browser dev",
    "browser:build": "corepack pnpm --filter @aura/browser build",
    "browser:event": "zsh scripts/run-aura-event.zsh",
    "browser:test:e2e": "corepack pnpm --filter @aura/browser test:e2e",
    "browser:package:mac": "corepack pnpm --filter @aura/browser package:mac",
    "dev": "corepack pnpm --filter @aura/shared build && corepack pnpm --parallel --filter @aura/extension --filter @aura/api dev",
    "demo:fixtures": "node scripts/serve-fixtures.mjs",
    "build": "corepack pnpm -r --if-present build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && corepack pnpm -r --if-present typecheck",
    "test": "corepack pnpm -r --if-present test",
    "test:e2e": "cross-env AURA_E2E=1 corepack pnpm build && playwright test"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "20.19.33",
    "cross-env": "^10.1.0",
    "eslint": "9.39.2",
    "globals": "16.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.0"
  }
}
