# AURA API
PORT=8787
NODE_ENV=development

# Provider credentials stay in the API process. Never expose them through WXT_* variables.
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
STT_PROVIDER=mock
STT_API_KEY=
STT_MODEL=gpt-4o-mini-transcribe

# Comma-separated exact origins. Add the unpacked extension origin for live API calls.
AURA_ALLOWED_ORIGINS=http://localhost:3000

# Public configuration: this is an endpoint only, never a secret.
WXT_PUBLIC_AURA_API_BASE_URL=http://localhost:8787
