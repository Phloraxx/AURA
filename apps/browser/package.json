{
  "name": "@aura/browser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": ".vite/main/index.js",
  "scripts": {
    "audit:page-intelligence": "node scripts/audit-page-intelligence.mjs",
    "audit:adaptation": "node scripts/audit-adaptation.mjs",
    "audit:conversation": "node scripts/audit-conversation.mjs",
    "audit:semantic": "node scripts/audit-semantic.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test:e2e": "playwright test -c playwright.config.ts",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run src",
    "package:mac": "pnpm build && electron-forge package --platform=darwin --arch=arm64"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "electron": "43.2.0",
    "electron-vite": "5.0.0",
    "happy-dom": "20.11.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "vite": "8.1.5"
  },
  "dependencies": {
    "openai": "6.48.0",
    "zod": "4.4.3"
  }
}
