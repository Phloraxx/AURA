    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@aura/shared": "workspace:*",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@wxt-dev/module-react": "1.1.4",
    "axe-core": "^4.12.1",
    "happy-dom": "20.11.0",
    "wxt": "0.20.10"
  }
}
