{
  "name": "@aura/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @aura/shared build",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prestart": "pnpm --filter @aura/shared build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm --filter @aura/shared build",
    "test": "vitest run --exclude 'dist/**'"
  },
  "dependencies": {
    "@aura/shared": "workspace:*",
    "@hono/node-server": "1.19.11",
    "hono": "4.12.30",
    "openai": "6.48.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "20.19.33",
    "tsx": "4.23.1"
  }
}
